# ===========================================
# Development Settings
# ===========================================
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ===========================================
# Production Settings (Dokku)
# ===========================================
# SECRET_KEY=generate-a-secure-64-char-key
# DEBUG=False
# ALLOWED_HOSTS=api.yourdomain.com
# DATABASE_URL=postgres://user:pass@host:5432/dbname  (auto-set by Dokku)
# CSRF_TRUSTED_ORIGINS=https://api.yourdomain.com
# SECURE_SSL_REDIRECT=True

# ===========================================
# Shopify API
# ===========================================
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=your-shopify-access-token

# ===========================================
# SMTP Email (Hostinger)
# ===========================================
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=your-email@yourdomain.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ===========================================
# Frontend URL (for password reset links)
# ===========================================
FRONTEND_URL=http://localhost:8081
# FRONTEND_URL=https://your-app-domain.com  (production)

# ===========================================
# CORS (comma-separated origins)
# ===========================================
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
# CORS_ALLOWED_ORIGINS=https://your-app-domain.com  (production)
